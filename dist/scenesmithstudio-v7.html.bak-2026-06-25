<div id="view-storyboard" class="view">
  <div class="page-wrap">

    <!-- No project state -->
    <div id="sb-no-project" style="display:none">
      <div class="coming-soon-view">
        <div class="cs-icon">🎬</div>
        <h2>Create a project first</h2>
        <p>Add characters and locations to your library — they'll be available for every panel.</p>
        <button class="btn btn-primary" onclick="openProjectManager(true)">＋ Create Project</button>
      </div>
    </div>

    <!-- Storyboard content -->
    <div id="sb-content">

      <!-- STORYBOARD ONBOARDING BANNER -->
      <div class="sb-onboarding-banner" id="sb-onboarding-banner" style="display:none">
        <div class="sb-onboarding-title">🎬 How to use Storyboard</div>
        <div class="sb-onboarding-steps">
          <div class="sb-onboarding-step"><span class="sb-onboarding-step-num">1</span><span>Add your <strong>Characters and Locations</strong> to the Library first — use <strong>@name</strong> to reference them in your story.</span></div>
          <div class="sb-onboarding-step"><span class="sb-onboarding-step-num">2</span><span>Write your story in the text area. Each sentence becomes a panel beat. Mention characters and locations by name.</span></div>
          <div class="sb-onboarding-step"><span class="sb-onboarding-step-num">3</span><span>Set your <strong>Platform</strong>, choose how many panels, and optionally add a <strong>Visual Style</strong> that travels to every panel.</span></div>
          <div class="sb-onboarding-step"><span class="sb-onboarding-step-num">4</span><span>Click <strong>Generate Storyboard</strong>. The app assigns shots, infers compositions, and builds cinematic prompts for each panel.</span></div>
          <div class="sb-onboarding-step"><span class="sb-onboarding-step-num">5</span><span>Review each panel's <strong>Composition</strong> block — edit it to adjust the spatial layout. The prompt updates live.</span></div>
        </div>
        <div class="sb-onboarding-extras">
          <span class="sb-onboarding-tip">✦ <strong>Enable Smart Split</strong> in Settings for director-level shot assignments via Claude API.</span>
          <span class="sb-onboarding-tip">✦ <strong>Spatial Context</strong> on your Location asset improves shot accuracy.</span>
        </div>
        <button class="sb-onboarding-dismiss" onclick="dismissSBOnboarding()" title="Dismiss">✕</button>
      </div>

      <!-- STEP 1: Story Input -->
      <div id="sb-step1" class="sb-step">
        <div class="page-header">
          <div>
            <h1 class="page-title">Sequence / Storyboard</h1>
            <p class="page-subtitle">Write your story using @mentions to link library assets. The app handles the rest.</p>
          </div>
        </div>

        <!-- Step 1: Story text with @ mentions -->
        <div class="sb-card">
          <div class="sb-card-title">Step 1 — Write Your Story</div>
          <p class="sb-card-hint">Write naturally. Use <strong>@name</strong> to link a library asset — character, location, prop, era. Type @ to see your library. Anything without an @ tag will be described by the AI.</p>
          <!-- Story textarea wrapper for @ picker positioning -->
          <div class="sb-story-wrap" id="sb-story-wrap">
            <div class="sb-story-display" id="sb-story-display"></div>
            <textarea class="input sb-story-input" id="sb-story-text"
              placeholder="e.g. @Raju is walking through @cityBg. He looks up and sees a @bird circling overhead…"
              rows="7"
              oninput="onSBStoryInput(event)"
              onkeydown="onSBStoryKeydown(event)"
              onfocus="analyseUnlinked(this.value)"
            ></textarea>
            <!-- @ picker dropdown -->
            <div class="sb-at-picker" id="sb-at-picker" style="display:none">
              <div class="sb-at-picker-list" id="sb-at-picker-list"></div>
            </div>
          </div>
          <!-- Unlinked element warnings -->
          <div id="sb-unlinked-warn" class="sb-unlinked-warn" style="display:none"></div>
        </div>

        <!-- Step 2: Panel config (asset selector removed — @ handles it) -->
        <div class="sb-card">
          <div class="sb-card-title">Step 2 — Panel Configuration</div>
          <div class="sb-config-row">
            <div class="sb-config-group">
              <div class="sb-config-label">Number of Panels</div>
              <div class="sb-panel-count-chips">
                <button class="sf-chip" data-val="3" onclick="setSBPanelCount(this)">3</button>
                <button class="sf-chip active" data-val="4" onclick="setSBPanelCount(this)">4</button>
                <button class="sf-chip" data-val="6" onclick="setSBPanelCount(this)">6</button>
                <button class="sf-chip" data-val="8" onclick="setSBPanelCount(this)">8</button>
                <button class="sf-chip" data-val="12" onclick="setSBPanelCount(this)">12</button>
              </div>
            </div>
            <div class="sb-config-group">
              <div class="sb-config-label">Platform</div>
              <div class="sb-panel-count-chips">
                <button class="sf-chip active" data-val="nb" onclick="setSBPlatform(this)">Nano Banana Pro</button>
                <button class="sf-chip" data-val="gpt" onclick="setSBPlatform(this)">GPT Image-2</button>
                <button class="sf-chip sb-mj-disabled" data-val="mj" title="Midjourney does not support storyboards" disabled>Midjourney ✕</button>
              </div>
            </div>
            <div class="sb-config-group">
              <div class="sb-config-label">Frame Aspect Ratio</div>
              <div class="sb-panel-count-chips" id="sb-ratio-chips">
                <button class="sf-chip active" data-val="16:9" onclick="setSBRatio(this)">16:9</button>
                <button class="sf-chip" data-val="4:3" onclick="setSBRatio(this)">4:3</button>
                <button class="sf-chip" data-val="1:1" onclick="setSBRatio(this)">1:1</button>
                <button class="sf-chip" data-val="9:16" onclick="setSBRatio(this)">9:16</button>
                <button class="sf-chip" data-val="2.39:1" onclick="setSBRatio(this)">2.39:1</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3: Style preferences -->
        <div class="sb-card">
          <div class="sb-card-title">Step 3 — Visual Style Preferences <span class="sb-optional">optional</span></div>
          <div class="sb-style-row">
            <div class="field">
              <label class="field-label">Overall Visual Style</label>
              <input class="input" id="sb-style" placeholder="e.g. epic mythological, documentary realism, dark fantasy">
            </div>
            <div class="field">
              <label class="field-label">Colour Mood</label>
              <input class="input" id="sb-colour" placeholder="e.g. warm amber tones, desaturated cool, golden hour throughout">
            </div>
            <div class="field">
              <label class="field-label">Camera Style</label>
              <input class="input" id="sb-camera" placeholder="e.g. handheld documentary, cinematic wide angles, intimate close-ups">
            </div>
          </div>
        </div>

        <!-- API Key for Smart Split -->
        <div class="sb-card sb-api-card">
          <div class="sb-card-title">
            Smart Split
            <span class="sb-online-badge">✦ Optional · Requires Anthropic API Key</span>
          </div>
          <p class="sb-card-hint">Smart Split uses Claude to intelligently break your story into dramatic panel beats. Without it, the app splits by sentence/paragraph (still works well).</p>
          <div id="sb-api-key-status" style="font-size:0.78rem;color:var(--ink-mid);display:flex;align-items:center;gap:8px;">
            <span id="sb-api-key-indicator">⬤</span>
            <span id="sb-api-key-label">No API key set</span>
            <button class="btn btn-ghost btn-sm" onclick="openSettings()">Configure in Settings →</button>
          </div>
        </div>

        <!-- Generate button -->
        <div class="sb-generate-row">
          <button class="btn btn-primary sb-generate-btn" id="sb-generate-btn" onclick="generateStoryboard()">
            Generate Panel Breakdown →
          </button>
          <span class="sb-generate-hint" id="sb-generate-hint"></span>
        </div>
      </div>

      <!-- STEP 5+: Panel breakdown (shown after generation) -->
      <div id="sb-step2" style="display:none">

        <!-- Header with back + export -->
        <div class="sb-panels-header">
          <div>
            <div class="sb-panels-title" id="sb-panels-title">Storyboard — 4 Panels</div>
            <div class="sb-panels-sub" id="sb-panels-platform-badge"></div>
          </div>
          <div class="sb-panels-actions">
            <button class="btn btn-secondary btn-sm" onclick="resetStoryboard()">← Edit Story</button>
            <button class="btn btn-secondary btn-sm" onclick="copyAllIndividual()">Copy Individual</button>
            <button class="btn btn-secondary btn-sm" onclick="copyAsGrid()">Copy as Grid</button>
            <button class="btn btn-primary btn-sm" onclick="saveStoryboardMD()">Save .md</button>
          </div>
        </div>

        <!-- Undo bar (hidden until cascade happens) -->
        <div id="sb-undo-bar" class="sb-undo-bar" style="display:none">
          <span class="sb-undo-msg" id="sb-undo-msg"></span>
          <button class="btn btn-secondary btn-sm" onclick="undoCascade()">↩ Undo</button>
        </div>

        <!-- Panel cards -->
        <div id="sb-panels-grid" class="sb-panels-grid"></div>

      </div>

    </div><!-- /sb-content -->

  </div><!-- /page-wrap -->
</div>

