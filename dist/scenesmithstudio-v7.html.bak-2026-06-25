<!-- ═══════════════════════════════════════════════════════════ -->
<!--  VIEW: LIBRARY                                              -->
<!-- ═══════════════════════════════════════════════════════════ -->
<div id="view-library" class="view active">
  <div class="page-wrap">

    <!-- No project state -->
    <div id="no-project-state" style="display:none">
      <div class="welcome-title">Build your <em>visual world</em>.</div>
      <p class="welcome-sub">Start by creating a project. Your characters, locations, props, and periods will live here — ready to inject into every prompt.</p>
      <button class="btn btn-primary" onclick="openProjectManager(true)">＋ Create first project</button>
    </div>

    <!-- Library content -->
    <div id="library-content">
      <div class="page-header">
        <div>
          <h1 class="page-title" id="library-project-name">Project Library</h1>
          <p class="page-subtitle">Define assets once — reuse across every prompt. No AI needed.</p>
        </div>
        <button class="btn btn-primary" onclick="openAssetModal(null, getCurrentType())">
          <span>＋</span> Add <span id="add-btn-type-label">Asset</span>
        </button>
      </div>

      <!-- Asset type tabs -->
      <div id="lib-type-tabs">
        <button class="lib-type-tab active" data-type="character" onclick="switchAssetType('character')">
          Characters <span class="lib-type-count" id="count-character">0</span>
        </button>
        <button class="lib-type-tab" data-type="location" onclick="switchAssetType('location')">
          Locations <span class="lib-type-count" id="count-location">0</span>
        </button>
        <button class="lib-type-tab" data-type="prop" onclick="switchAssetType('prop')">
          Props <span class="lib-type-count" id="count-prop">0</span>
        </button>
        <button class="lib-type-tab" data-type="era" onclick="switchAssetType('era')">
          Era &amp; Context <span class="lib-type-count" id="count-era">0</span>
        </button>
        <button class="lib-type-tab" data-type="style" onclick="switchAssetType('style')">
          Background Style <span class="lib-type-count" id="count-style">0</span>
        </button>
      </div>

      <!-- Asset grid -->
      <div id="asset-grid"></div>
    </div>

  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<!--  VIEW: SINGLE FRAME                                         -->
<!-- ═══════════════════════════════════════════════════════════ -->
<div id="view-single" class="view">
  <div class="sf-layout">

    <!-- LEFT: Layer Stack -->
    <div class="sf-left" id="sf-left">

      <!-- No project warning -->
      <div id="sf-no-project" style="display:none">
        <div class="sf-noproj-msg">
          <p>Create a project first to use the Single Frame builder.</p>
          <button class="btn btn-primary btn-sm" onclick="openProjectManager(true)">＋ Create Project</button>
        </div>
      </div>

      <div id="sf-stack">

        <!-- ONBOARDING BANNER — shown once, dismissible -->
        <div class="sf-onboarding-banner" id="sf-onboarding-banner">
          <div class="sf-onboarding-title">🎬 How to build a prompt</div>
          <div class="sf-onboarding-steps">
            <div class="sf-onboarding-step"><span class="sf-onboarding-step-num">1</span><span>Select your <strong>Library Assets</strong> — characters, locations, props you've defined. Their descriptions auto-inject into the prompt.</span></div>
            <div class="sf-onboarding-step"><span class="sf-onboarding-step-num">2</span><span>Pick a <strong>Frame Size</strong> — the app auto-selects the right lens and depth of field for you.</span></div>
            <div class="sf-onboarding-step"><span class="sf-onboarding-step-num">3</span><span>Describe the <strong>action or scene</strong> in the Subject field. Type <strong>@name</strong> to link a library asset inline.</span></div>
            <div class="sf-onboarding-step"><span class="sf-onboarding-step-num">4</span><span>Adjust <strong>Lighting, Mood, and Quality</strong> as needed — or leave defaults. The prompt builds live on the right.</span></div>
            <div class="sf-onboarding-step"><span class="sf-onboarding-step-num">5</span><span>Select your <strong>Platform</strong> at the bottom, copy the prompt, and paste into your AI image generator.</span></div>
          </div>
          <div class="sf-onboarding-extras">
            <span class="sf-onboarding-tip">✦ <strong>Dashed amber chip</strong> = auto-suggested by the app. Click to change.</span>
            <span class="sf-onboarding-tip">＋ <strong>Plus button</strong> on any chip group = add your own keyword. Right-click a custom chip to delete it.</span>
            <span class="sf-onboarding-tip">🎭 <strong>Signature Techniques</strong> = advanced cinematic effects — toggle on for richer output.</span>
          </div>
          <button class="sf-onboarding-dismiss" onclick="dismissOnboarding()">✕ Got it</button>
        </div>

        <!-- OUTPUT TYPE -->
        <div class="sf-section">
          <div class="sf-section-label">Output Type</div>
          <div class="sf-toggle-row" id="sf-output-type">
            <button class="sf-toggle active" data-val="still" onclick="setSFOutputType('still')">Still Image</button>
            <button class="sf-toggle" data-val="motion" onclick="setSFOutputType('motion')">Motion Poster</button>
          </div>
        </div>

        <!-- LAYER 1: LIBRARY ASSETS -->
        <div class="sf-section">
          <div class="sf-section-label">Library Assets <span class="sf-label-hint">auto-injects descriptions</span></div>
          <div id="sf-asset-selector" class="sf-asset-chips"></div>
        </div>

        <!-- LAYER 2: GENRE / STYLE PRESET -->
        <div class="sf-section">
          <div class="sf-section-label">Genre / Style <span class="sf-label-hint">optional — loads vocabulary</span></div>
          <div class="sf-chips" id="sf-genre-chips">
            <!-- populated by renderSFGenreChips() on init -->
          </div>
        </div>

        <!-- LAYER 3: SUBJECT -->
        <div class="sf-section">
          <div class="sf-section-label">Subject <button class="sf-vocab-add-btn" title="Add to Vocabulary" onclick="openVocabQuickAdd('subject')">⊕</button></div>
          <div class="sf-chips" id="sf-subject-chips"></div>
          <div style="position:relative">
            <textarea class="input sf-textarea" id="sf-subject-text"
              placeholder="Describe your subject — type @ to link a library asset"
              rows="2"
              oninput="onSFFieldInput(event,'sf-subject-text','sf-at-picker-subject','sf-at-list-subject')"
              onkeydown="onSFFieldKeydown(event,'sf-subject-text','sf-at-picker-subject','sf-at-list-subject')"
            ></textarea>
            <div class="sb-at-picker" id="sf-at-picker-subject" style="display:none">
              <div class="sb-at-picker-list" id="sf-at-list-subject"></div>
            </div>
          </div>
        </div>

        <!-- LAYER 4 & 5: FRAME SIZE + SHOT ANGLE -->
        <div class="sf-section">
          <div class="sf-section-label">Frame Size</div>
          <div class="sf-frame-cards" id="sf-frame-cards">
            <button class="sf-frame-card" data-val="face" onclick="setSFFrame(this)">
              <div class="sf-frame-icon">👁</div>
              <div class="sf-frame-label">Face Only</div>
              <div class="sf-frame-sub">Extreme close-up</div>
            </button>
            <button class="sf-frame-card" data-val="head" onclick="setSFFrame(this)">
              <div class="sf-frame-icon">🧑</div>
              <div class="sf-frame-label">Head & Shoulders</div>
              <div class="sf-frame-sub">Portrait</div>
            </button>
            <button class="sf-frame-card" data-val="waist" onclick="setSFFrame(this)">
              <div class="sf-frame-icon">🙆</div>
              <div class="sf-frame-label">Waist Up</div>
              <div class="sf-frame-sub">Medium shot</div>
            </button>
            <button class="sf-frame-card" data-val="fullbody" onclick="setSFFrame(this)">
              <div class="sf-frame-icon">🧍</div>
              <div class="sf-frame-label">Full Body</div>
              <div class="sf-frame-sub">Full figure</div>
            </button>
            <button class="sf-frame-card" data-val="wide" onclick="setSFFrame(this)">
              <div class="sf-frame-icon">🌄</div>
              <div class="sf-frame-label">Wide / Scene</div>
              <div class="sf-frame-sub">Environmental</div>
            </button>
          </div>
          <!-- Auto-inject banner -->
          <div id="sf-auto-inject-banner" style="display:none">
            <div class="sf-auto-banner">
              <span class="sf-auto-label">Auto-added for this frame</span>
              <div id="sf-auto-inject-chips" class="sf-auto-chips"></div>
            </div>
          </div>
        </div>

        <!-- SHOT ANGLE -->
        <div class="sf-section">
          <div class="sf-section-label">Shot Angle</div>
          <div class="sf-chips single-select" id="sf-angle-chips">
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="eye level" onclick="toggleSFChip(this,'angle',true)">Eye Level</button><span class="chip-tip">Camera at subject's eye height. Natural, neutral — the way we normally see the world.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="low angle" onclick="toggleSFChip(this,'angle',true)">Low Angle</button><span class="chip-tip">Camera below the subject looking up. Makes the subject appear powerful, dominant, larger than life.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="high angle" onclick="toggleSFChip(this,'angle',true)">High Angle</button><span class="chip-tip">Camera above the subject looking down. Makes the subject appear smaller, vulnerable, or observed.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="bird's eye view" onclick="toggleSFChip(this,'angle',true)">Bird's Eye</button><span class="chip-tip">Directly overhead, looking straight down. Reveals layout and pattern. Subject becomes part of environment.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="over-the-shoulder" onclick="toggleSFChip(this,'angle',true)">Over-Shoulder</button><span class="chip-tip">Camera behind one character, facing another. Classic dialogue and confrontation framing.</span></span>
          </div>
          <div style="margin-top:8px;">
            <span class="sf-chip-wrap">
              <button class="sf-chip" id="sf-dutch-angle-chip" onclick="toggleDutchAngle(this)">Dutch Angle</button>
              <span class="chip-tip">Camera tilted on its axis — creates unease, tension, or disorientation. Can combine with any vertical angle.</span>
            </span>
          </div>
        </div>

        <!-- LAYER 6: ASPECT RATIO -->
        <div class="sf-section">
          <div class="sf-section-label">Aspect Ratio</div>
          <div class="sf-ratio-cards" id="sf-ratio-cards">
            <button class="sf-ratio-card" data-val="16:9" onclick="setSFRatio(this)">
              <div class="sf-ratio-preview ratio-16-9"></div>
              <div class="sf-ratio-label">16:9</div>
              <div class="sf-ratio-sub">Landscape</div>
            </button>
            <button class="sf-ratio-card" data-val="9:16" onclick="setSFRatio(this)">
              <div class="sf-ratio-preview ratio-9-16"></div>
              <div class="sf-ratio-label">9:16</div>
              <div class="sf-ratio-sub">Portrait</div>
            </button>
            <button class="sf-ratio-card" data-val="1:1" onclick="setSFRatio(this)">
              <div class="sf-ratio-preview ratio-1-1"></div>
              <div class="sf-ratio-label">1:1</div>
              <div class="sf-ratio-sub">Square</div>
            </button>
            <button class="sf-ratio-card" data-val="4:5" onclick="setSFRatio(this)">
              <div class="sf-ratio-preview ratio-4-5"></div>
              <div class="sf-ratio-label">4:5</div>
              <div class="sf-ratio-sub">Social</div>
            </button>
            <button class="sf-ratio-card" data-val="3:2" onclick="setSFRatio(this)">
              <div class="sf-ratio-preview ratio-3-2"></div>
              <div class="sf-ratio-label">3:2</div>
              <div class="sf-ratio-sub">Classic</div>
            </button>
            <button class="sf-ratio-card" data-val="2:3" onclick="setSFRatio(this)">
              <div class="sf-ratio-preview ratio-2-3"></div>
              <div class="sf-ratio-label">2:3</div>
              <div class="sf-ratio-sub">Tall</div>
            </button>
          </div>
        </div>

        <!-- LAYER 7 & 8: WARDROBE & MATERIAL -->
        <div class="sf-section">
          <div class="sf-section-label">Wardrobe & Props <button class="sf-vocab-add-btn" title="Add to Vocabulary" onclick="openVocabQuickAdd('wardrobe')">⊕</button></div>
          <div class="sf-chips" id="sf-wardrobe-chips"></div>
          <div style="position:relative">
            <textarea class="input sf-textarea" id="sf-wardrobe-text"
              placeholder="Specific costume, fabric, accessories, props in hand — type @ to link a library asset"
              rows="2"
              oninput="onSFFieldInput(event,'sf-wardrobe-text','sf-at-picker-wardrobe','sf-at-list-wardrobe')"
              onkeydown="onSFFieldKeydown(event,'sf-wardrobe-text','sf-at-picker-wardrobe','sf-at-list-wardrobe')"
            ></textarea>
            <div class="sb-at-picker" id="sf-at-picker-wardrobe" style="display:none">
              <div class="sb-at-picker-list" id="sf-at-list-wardrobe"></div>
            </div>
          </div>
        </div>

        <div class="sf-section">
          <div class="sf-section-label">Material Condition</div>
          <div class="sf-chips single-select" id="sf-condition-chips">
            <button class="sf-chip" data-val="pristine" onclick="toggleSFChip(this,'condition',true)">Pristine</button>
            <button class="sf-chip" data-val="well-maintained" onclick="toggleSFChip(this,'condition',true)">Well-maintained</button>
            <button class="sf-chip" data-val="lightly worn" onclick="toggleSFChip(this,'condition',true)">Lightly Worn</button>
            <button class="sf-chip" data-val="battle-worn" onclick="toggleSFChip(this,'condition',true)">Battle-worn</button>
            <button class="sf-chip" data-val="aged" onclick="toggleSFChip(this,'condition',true)">Aged</button>
            <button class="sf-chip" data-val="decayed" onclick="toggleSFChip(this,'condition',true)">Decayed</button>
            <button class="sf-chip" data-val="mud-caked" onclick="toggleSFChip(this,'condition',true)">Mud-caked</button>
            <button class="sf-chip" data-val="rain-soaked" onclick="toggleSFChip(this,'condition',true)">Rain-soaked</button>
          </div>
        </div>

        <!-- LAYER 9: ENVIRONMENT -->
        <div class="sf-section">
          <div class="sf-section-label">Environment <button class="sf-vocab-add-btn" title="Add to Vocabulary" onclick="openVocabQuickAdd('env')">⊕</button></div>
          <div class="sf-chips" id="sf-env-chips"></div>
          <div style="position:relative">
            <textarea class="input sf-textarea" id="sf-env-text"
              placeholder="Setting, location — type @ to link a library asset"
              rows="2"
              oninput="onSFFieldInput(event,'sf-env-text','sf-at-picker-env','sf-at-list-env')"
              onkeydown="onSFFieldKeydown(event,'sf-env-text','sf-at-picker-env','sf-at-list-env')"
            ></textarea>
            <div class="sb-at-picker" id="sf-at-picker-env" style="display:none">
              <div class="sb-at-picker-list" id="sf-at-list-env"></div>
            </div>
          </div>
        </div>

        <!-- LAYER 10 & 11: LIGHTING -->
        <div class="sf-section">
          <div class="sf-section-label">Lighting Setup</div>
          <div style="font-size:0.7rem;color:var(--ink-lt);margin-bottom:6px;font-style:italic;">Technique</div>
          <div class="sf-chips" id="sf-lighting-chips">
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="Rembrandt lighting" onclick="toggleSFChip(this,'lighting-setup')">Rembrandt</button><span class="chip-tip">Warm triangle of light on one cheek, the other side falls into shadow. Classic portrait drama.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="rim lighting" onclick="toggleSFChip(this,'lighting-setup')">Rim Light</button><span class="chip-tip">Light source behind the subject creates a glowing outline edge. Subject pops from background.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="window light, soft directional from single source" onclick="toggleSFChip(this,'lighting-setup')">Window Light</button><span class="chip-tip">Soft, directional natural light from a single side. Gentle shadows, intimate feel.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="three-point lighting setup" onclick="toggleSFChip(this,'lighting-setup')">Three-Point</button><span class="chip-tip">Key light + fill light + rim light. Standard professional setup — balanced, clear, no harsh shadows.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="practical light sources only — candles, fire, oil lamps" onclick="toggleSFChip(this,'lighting-setup')">Practical Only</button><span class="chip-tip">All light comes from visible sources in the scene — candles, fire, lamps. No artificial fill.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="volumetric light rays, god rays through atmosphere" onclick="toggleSFChip(this,'lighting-setup')">Volumetric</button><span class="chip-tip">Visible light beams cutting through dust, smoke or mist. Often called god rays.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="split lighting — half face lit, half in shadow" onclick="toggleSFChip(this,'lighting-setup')">Split</button><span class="chip-tip">Exactly half the face lit, the other half in complete shadow. High drama, intense mood.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="butterfly lighting — light from directly above" onclick="toggleSFChip(this,'lighting-setup')">Butterfly</button><span class="chip-tip">Light directly above the face creates a small butterfly-shaped shadow under the nose. Glamorous look.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="golden divine light emanating from subject" onclick="toggleSFChip(this,'lighting-setup')">Divine Light</button><span class="chip-tip">Warm golden glow emanating from or around the subject. Used in spiritual and devotional scenes.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="dramatic storm light — low-angle breaks in dark clouds, violent lightning" onclick="toggleSFChip(this,'lighting-setup')">Storm Light</button><span class="chip-tip">Low-angle breaks in dark clouds create harsh dramatic shafts. High contrast, electric atmosphere.</span></span>
          </div>
          <div style="font-size:0.7rem;color:var(--ink-lt);margin:8px 0 6px;font-style:italic;">Natural & Environmental</div>
          <div class="sf-chips" id="sf-lighting-natural-chips">
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="bright daylight, strong direct sunlight, crisp shadows, high visibility" onclick="toggleSFChip(this,'lighting-natural')">Bright Daylight</button><span class="chip-tip">Strong, clear sunlight with crisp defined shadows. Colours vivid and saturated. High energy feel.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="overcast sky, diffused even light, flat soft shadows, natural colour balance" onclick="toggleSFChip(this,'lighting-natural')">Overcast</button><span class="chip-tip">Clouds act as a giant softbox. Even, flattering light from all directions. No harsh shadows.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="hazy sun, soft warm glow through thin clouds, gentle shadows" onclick="toggleSFChip(this,'lighting-natural')">Hazy Sun</button><span class="chip-tip">Sun visible but softened by thin cloud or haze. Warm diffused glow, gentle shadows.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="harsh midday sun, overhead light, short dark shadows, high contrast" onclick="toggleSFChip(this,'lighting-natural')">Harsh Midday</button><span class="chip-tip">Overhead sun creates unflattering short shadows and high contrast. Raw, unforgiving, intense feel.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="dappled forest light, sunlight filtering through tree canopy" onclick="toggleSFChip(this,'lighting-natural')">Dappled Forest</button><span class="chip-tip">Sunlight breaking through leaves creates patches of light and shadow. Magical, natural, layered.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="foggy misty atmosphere, diffused ambient light, reduced visibility, ethereal" onclick="toggleSFChip(this,'lighting-natural')">Foggy / Misty</button><span class="chip-tip">Moisture in the air scatters light, softening everything. Mysterious, atmospheric, dreamlike.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="backlit silhouette, strong light source directly behind subject, subject in shadow" onclick="toggleSFChip(this,'lighting-natural')">Backlit Silhouette</button><span class="chip-tip">Light source behind the subject puts them in shadow. Dramatic outline, subject becomes a shape.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="candlelit interior, warm flickering amber light, deep surrounding shadows" onclick="toggleSFChip(this,'lighting-natural')">Candlelit Interior</button><span class="chip-tip">Warm, intimate, flickering amber light. Deep shadows beyond the flame. Ancient, personal feel.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="neon night, mixed coloured artificial light sources, urban night atmosphere" onclick="toggleSFChip(this,'lighting-natural')">Neon Night</button><span class="chip-tip">City at night lit by neon signs and artificial lights. Coloured reflections on wet surfaces. Cyberpunk or noir feel.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="blue hour, post-sunset deep blue sky, balanced ambient and artificial light" onclick="toggleSFChip(this,'lighting-natural')">Blue Hour</button><span class="chip-tip">The 20 minutes after sunset when the sky turns deep blue. Cool tones, serene mood, city lights begin to glow.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="fire glow, warm orange-red light from open flame, dancing shadows" onclick="toggleSFChip(this,'lighting-natural')">Fire Glow</button><span class="chip-tip">Open fire as primary light source. Warm orange-red tones, moving shadows, primal atmosphere.</span></span>
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="moonlit night, cold blue-white ambient light, long soft shadows" onclick="toggleSFChip(this,'lighting-natural')">Moonlit</button><span class="chip-tip">Moonlight casts a cold, blue-white ambient glow. Quiet, ethereal, mysterious night atmosphere.</span></span>
          </div>
        </div>

        <div class="sf-section">
          <div class="sf-section-label">Time of Day</div>
          <div class="sf-chips single-select" id="sf-tod-chips">
            <button class="sf-chip" data-val="dawn — soft pink-gold horizon light, long shadows, cool air haze" data-label="Dawn" onclick="toggleSFChip(this,'tod',true)">Dawn</button>
            <button class="sf-chip" data-val="early morning — low warm directional light, long soft shadows" data-label="Early Morning" onclick="toggleSFChip(this,'tod',true)">Early Morning</button>
            <button class="sf-chip" data-val="late morning — bright warm illumination, even spread, minimal shadows" data-label="Late Morning" onclick="toggleSFChip(this,'tod',true)">Late Morning</button>
            <button class="sf-chip" data-val="harsh overhead midday light, short dark shadows, high contrast" data-label="Midday" onclick="toggleSFChip(this,'tod',true)">Midday</button>
            <button class="sf-chip" data-val="golden hour — warm amber directional light, long shadows, rim lighting" data-label="Golden Hour" onclick="toggleSFChip(this,'tod',true)">Golden Hour</button>
            <button class="sf-chip" data-val="dusk — deep orange-red horizon, dramatic silhouettes, warm-cool split" data-label="Dusk" onclick="toggleSFChip(this,'tod',true)">Dusk</button>
            <button class="sf-chip" data-val="night — artificial light sources, deep shadows, high contrast pools of light" data-label="Night" onclick="toggleSFChip(this,'tod',true)">Night</button>
            <button class="sf-chip" data-val="overcast — diffused even light, soft shadows, natural colour balance" data-label="Overcast" onclick="toggleSFChip(this,'tod',true)">Overcast</button>
          </div>
        </div>

        <!-- LAYER 12 & 13: CAMERA -->
        <div class="sf-section">
          <div class="sf-section-label">Camera & Lens <span class="sf-label-hint">auto-suggested by frame + mood</span></div>
          <div id="sf-camera-auto" class="sf-camera-auto-display" style="display:none"></div>
          <div class="sf-chips" id="sf-lens-chips">
            <span class="sf-chip-wrap"><button class="sf-chip" data-val="14-24mm ultra-wide lens" onclick="toggleSFChip(this,'lens')">14–24mm Ultra-wide</button><span class="chip-tip">Very wide field of view. Dramatic perspective, slight distortion at edges. Great for environments and action.</span></span>
