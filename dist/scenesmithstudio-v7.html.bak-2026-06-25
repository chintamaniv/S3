    }
  });
  const sentences = story
    .replace(/([.!?।])\s+/g, '$1\n')
    .replace(/,?\s+(then|suddenly|meanwhile|meanwhile,|as |next|finally|after that|at that moment|moments later|just then),?\s+/gi, '\n')
