<!--  MODAL: SETTINGS                                            -->
<!-- ═══════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="settings-modal-overlay" onclick="handleOverlayClick(event,'settings-modal-overlay')">
  <div class="modal" id="settings-modal" style="max-width:860px;width:95vw">
    <div class="modal-header">
      <h2 class="modal-title">Settings</h2>
      <button class="modal-close" onclick="closeModal('settings-modal-overlay')">✕</button>
    </div>

    <!-- Settings Tabs -->
    <div class="settings-tabs">
      <button class="settings-tab active" data-tab="api" onclick="switchSettingsTab('api')">API Keys</button>
      <button class="settings-tab" data-tab="vocab" onclick="switchSettingsTab('vocab')">Vocabulary</button>
      <button class="settings-tab" data-tab="sponsor" onclick="switchSettingsTab('sponsor')">Sponsor</button>
      <button class="settings-tab" data-tab="danger" onclick="switchSettingsTab('danger')">Danger Zone</button>
    </div>

    <div class="modal-body">

      <!-- ── TAB: API KEYS ──────────────────────────────────── -->
      <div class="settings-tab-panel" id="settings-panel-api">
        <div class="settings-group">
          <div class="settings-group-title">API Keys</div>

          <!-- Anthropic -->
          <div class="settings-api-row">
            <div class="settings-api-label">
              Anthropic (Claude)
              <span class="api-badge api-badge-active" id="anthropic-status-badge">No key</span>
              <label style="display:flex;align-items:center;gap:5px;margin-left:auto;cursor:pointer;font-size:0.75rem;font-weight:500;color:var(--ink-mid);">
                <input type="checkbox" id="settings-anthropic-active"
                  onchange="saveApiActive('anthropic', this.checked); updateApiKeyIndicator()"
                  style="accent-color:var(--amber);">
                Use API — enable Smart Split &amp; Image Analysis
              </label>
            </div>
            <div class="settings-api-input-row">
              <input class="input" id="settings-anthropic-key" type="password"
                placeholder="sk-ant-api03-…"
                autocomplete="off"
                oninput="saveApiKey('anthropic', this.value)">
              <button class="btn btn-secondary btn-sm" onclick="toggleKeyVisibility('settings-anthropic-key', this)">Show</button>
            </div>
            <div class="settings-api-hint">
              Used for Smart Split and Image Analysis.<br>
              <a href="https://console.anthropic.com/account/keys" target="_blank">Get your Anthropic API key →</a>
              &nbsp;·&nbsp; Stored in your browser only. Never sent anywhere except Anthropic's API.
            </div>
          </div>

          <!-- Google (Gemini) -->
          <div class="settings-api-row">
            <div class="settings-api-label">
              Google AI Studio (Gemini)
              <span class="api-badge api-badge-active" id="gemini-status-badge">No key</span>
              <label style="display:flex;align-items:center;gap:5px;margin-left:auto;cursor:pointer;font-size:0.75rem;font-weight:500;color:var(--ink-mid);">
                <input type="checkbox" id="settings-gemini-active"
                  onchange="saveApiActive('gemini', this.checked); updateApiKeyIndicator()"
                  style="accent-color:var(--amber);">
                Use API — enable Image Analysis
              </label>
            </div>
            <div class="settings-api-input-row">
              <input class="input" id="settings-gemini-key" type="password"
                placeholder="AIza…"
                autocomplete="off"
                oninput="saveApiKey('gemini', this.value)">
              <button class="btn btn-secondary btn-sm" onclick="toggleKeyVisibility('settings-gemini-key', this)">Show</button>
            </div>
            <div class="settings-api-hint">
              Used for Image Analysis (vision). Does not generate images — Nano Banana Pro generation still happens in Gemini directly.<br>
              <a href="https://aistudio.google.com/app/apikey" target="_blank">Get your Gemini API key →</a>
              &nbsp;·&nbsp; Stored in your browser only. Never sent anywhere except Google's API.
            </div>
          </div>

          <!-- Vision provider choice -->
          <div class="settings-api-row" id="vision-provider-row">
            <div class="settings-api-label">Vision provider for Image Analysis</div>
            <div class="settings-api-input-row">
              <select class="input" id="settings-vision-provider"
                onchange="saveVisionProvider(this.value)" style="max-width:240px">
                <option value="anthropic">Claude (Anthropic)</option>
                <option value="gemini">Gemini (Google)</option>
              </select>
            </div>
            <div class="settings-api-hint">
              Choose which API the "✦ Analyse" button on character/asset images uses. Switch here any time — e.g. if one provider is down or out of credits.
            </div>
          </div>

          <!-- OpenAI — coming soon -->
          <div class="settings-api-row settings-api-disabled">
            <div class="settings-api-label">
              OpenAI
              <span class="api-badge api-badge-soon">Coming Soon</span>
              <label style="display:flex;align-items:center;gap:5px;margin-left:auto;cursor:not-allowed;font-size:0.75rem;font-weight:500;color:var(--ink-lt);">
                <input type="checkbox" disabled style="accent-color:var(--amber);">
                Use API (coming soon)
              </label>
            </div>
            <div class="settings-api-input-row">
              <input class="input" type="password" placeholder="sk-…" disabled>
            </div>
            <div class="settings-api-hint">Will power direct GPT Image-2 generation and image analysis.</div>
          </div>
        </div>
      </div>

      <!-- ── TAB: VOCABULARY ────────────────────────────────── -->
      <div class="settings-tab-panel" id="settings-panel-vocab" style="display:none">
        <div id="vocab-manager-root"></div>
      </div>

      <!-- ── TAB: SPONSOR ───────────────────────────────────── -->
      <div class="settings-tab-panel" id="settings-panel-sponsor" style="display:none">
        <div class="settings-group">
          <div class="settings-group-title">Sponsor teammates</div>
          <p class="field-hint" style="margin-bottom:14px">
            Share your own API key with specific teammates so they can use Image Analysis without
            needing a key of their own. Your key is sent once over HTTPS, stored encrypted on the
            server, and is <strong>never sent to their browser</strong> — every analysis request is
            relayed through the server.
          </p>

          <div class="settings-api-row">
            <div class="settings-api-label">Re-enter your password to manage sponsoring</div>
            <div class="settings-api-input-row">
              <input class="input" id="sponsor-confirm-password" type="password"
                placeholder="Your account password" autocomplete="current-password">
              <button class="btn btn-secondary btn-sm" onclick="loadSponsorSettingsUI()">Unlock</button>
            </div>
            <div class="settings-api-hint" id="sponsor-unlock-hint"></div>
          </div>

          <div id="sponsor-managed-section" style="display:none">
            <div class="settings-api-row">
              <div class="settings-api-label">Your Anthropic key for sponsoring</div>
              <div class="settings-api-input-row">
                <input class="input" id="sponsor-anthropic-key" type="password"
                  placeholder="Leave blank to keep current key" autocomplete="off">
                <button class="btn btn-secondary btn-sm" onclick="toggleKeyVisibility('sponsor-anthropic-key', this)">Show</button>
              </div>
              <div class="settings-api-hint" id="sponsor-anthropic-status"></div>
            </div>

            <div class="settings-api-row">
              <div class="settings-api-label">Your Gemini key for sponsoring</div>
              <div class="settings-api-input-row">
                <input class="input" id="sponsor-gemini-key" type="password"
                  placeholder="Leave blank to keep current key" autocomplete="off">
                <button class="btn btn-secondary btn-sm" onclick="toggleKeyVisibility('sponsor-gemini-key', this)">Show</button>
              </div>
              <div class="settings-api-hint" id="sponsor-gemini-status"></div>
            </div>

            <div class="settings-api-row">
              <div class="settings-api-label">Teammates allowed to use your key</div>
              <div class="settings-api-input-row">
                <input class="input" id="sponsor-add-username" placeholder="Username to add" maxlength="50">
                <button class="btn btn-secondary btn-sm" onclick="addSponsoredUsername()">Add</button>
              </div>
              <div id="sponsor-username-list" style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px;"></div>
              <div class="settings-api-hint">Only usernames listed here can use your sponsored key — exact match required.</div>
            </div>

            <button class="btn btn-primary" onclick="saveSponsorSettings()">Save sponsor settings</button>
            <span id="sponsor-save-status" style="margin-left:10px;font-size:0.85rem;color:var(--ink-mid)"></span>
          </div>
        </div>
      </div>

      <!-- ── TAB: DANGER ZONE ───────────────────────────────── -->
      <div class="settings-tab-panel" id="settings-panel-danger" style="display:none">
        <div class="field" style="margin-top:8px">
          <label class="field-label" style="color:var(--red)">Reset App</label>
          <p class="field-hint">Clears all projects, library assets, custom vocabulary, and saved settings. Cannot be undone.</p>
          <button class="btn btn-danger" style="margin-top:4px" onclick="confirmResetApp()">Clear all data</button>
        </div>
      </div>

    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('settings-modal-overlay')">Done</button>
    </div>
  </div>
</div>

